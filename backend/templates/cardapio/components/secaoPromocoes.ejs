<table class="secao-table secao-table--grid<%= secao.novaPagina ? " secao-table--nova-pagina" : "" %>">
  <thead>
    <tr>
      <td colspan="2">
        <% if (secao.comDivisor) { %><%- include("divisor") %><% } %>
        <div class="secao-head">
          <span class="num">Nº <%= String(secao.numero).padStart(2, "0") %></span>
          <h2>Promoções</h2>
          <span class="tag">Leve mais, pague menos</span>
        </div>
      </td>
    </tr>
  </thead>
  <tbody>
    <% for (var i = 0; i < secao.promocoes.length; i += 2) { %>
      <tr>
        <td><%- include("promocaoCard", { p: secao.promocoes[i], fmtBRL: fmtBRL }) %></td>
        <td><% if (secao.promocoes[i + 1]) { %><%- include("promocaoCard", { p: secao.promocoes[i + 1], fmtBRL: fmtBRL }) %><% } %></td>
      </tr>
    <% } %>
  </tbody>
  <tfoot>
    <tr><td colspan="2"><div class="rodape-espacador"></div></td></tr>
  </tfoot>
</table>
