<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8" />
<title>Cardápio<%= (restaurante && restaurante.nome) ? " — " + restaurante.nome : "" %></title>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

<style>
  /* Paleta/tipografia/regras de quebra portadas de frontend/src/pages/CardapioPDF/CardapioPDF.css. */
  @page { margin: 0; }

  * { print-color-adjust: exact; -webkit-print-color-adjust: exact; }

  html, body { margin: 0; padding: 0; background: #0d1117; }
  body {
    font-family: "Manrope", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  .cardapio-doc {
    --amber: #fbbf24;
    --orange: #fb923c;
    --violet: #c4b5fd;
    --violet-strong: #a78bfa;
    --green: #34d399;
    background: #0d1117;
    color: #e2e8f0;
    padding: 0 0.7in;
  }

  /* Moldura + rodapé fixos: position:fixed em contexto de impressão se repete
     automaticamente idêntico em toda página. Como um fixed não tem como "pular"
     só a capa via CSS puro, a capa é renderizada num PDF separado (sem rodapé
     no DOM) e depois unida ao PDF do restante do conteúdo — ver gerarPDF em
     cardapio.controller.ts. */
  .pagina-moldura { position: fixed; top: 6px; left: 6px; right: 6px; bottom: 6px; border: 1px solid rgba(251,191,36,.4); pointer-events: none; }
  .rodape-fixo {
    position: fixed; left: 0; right: 0; bottom: 16px;
    display: flex; align-items: center; justify-content: center; gap: 8px; flex-wrap: wrap;
    padding: 14px 0.7in 0; font-size: 8.5px; letter-spacing: 1.2px; text-transform: uppercase;
    color: #475569; font-weight: 600;
  }
  .rodape-fixo::before {
    content: ""; position: absolute; top: 0; left: 20%; right: 20%; height: 1px;
    background: linear-gradient(to right, transparent, rgba(251,191,36,.45), transparent);
  }
  .rodape-fixo .ponto { color: rgba(251,191,36,.4); }

  /* ══ Capa ══
     Agora que a capa vira sua própria página (quebra forçada antes da primeira
     seção), ela ocupa a altura útil inteira da folha: moldura com cantos, miolo
     centralizado e, na base, um índice de categorias + data como prévia do resto
     do documento. */
  .capa {
    position: relative; display: flex; flex-direction: column;
    justify-content: space-between; align-items: center; text-align: center;
    min-height: 9.5in; padding: 80px 10px 30px; break-after: avoid; margin-top: 50px;
  }
  .capa::before, .capa::after {
    content: ""; position: absolute; left: 50%; transform: translateX(-50%);
    height: 1px; width: 100%;
    background: linear-gradient(to right, transparent, rgba(251,191,36,.55), transparent);
  }
  .capa::before { top: 0; }
  .capa::after { bottom: 0; }
  .capa-canto { position: absolute; width: 30px; height: 30px; border: 1px solid rgba(251,191,36,.32); }
  .capa-canto--tl { top: 16px; left: 0; border-right: none; border-bottom: none; }
  .capa-canto--tr { top: 16px; right: 0; border-left: none; border-bottom: none; }
  .capa-canto--bl { bottom: 16px; left: 0; border-right: none; border-top: none; }
  .capa-canto--br { bottom: 16px; right: 0; border-left: none; border-top: none; }
  .capa-marca { font-size: 11px; letter-spacing: 5px; text-transform: uppercase; color: #475569; font-weight: 600; }
  .capa-miolo { position: relative; }
  .capa-miolo::before {
    content: ""; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 380px; height: 380px; border-radius: 50%;
    background: radial-gradient(circle, rgba(251,191,36,.13), transparent 70%);
    z-index: 0;
  }
  .capa-miolo > * { position: relative; z-index: 1; }
  .capa .ornamento { display: flex; align-items: center; justify-content: center; gap: 14px; margin-bottom: 16px; }
  .capa .ornamento span { display: block; width: 54px; height: 1px; background: linear-gradient(to right, transparent, rgba(251,191,36,.7)); }
  .capa .ornamento span:last-child { transform: scaleX(-1); }
  .capa img { width: 112px; height: 112px; margin-top: 14px; object-fit: contain; filter: drop-shadow(0 0 16px rgba(251,191,36,.4)); }
  .capa h1 {
    margin: 14px 0 0; font-family: "Bebas Neue", sans-serif; font-weight: 400;
    font-size: 68px; line-height: 1; letter-spacing: 7px;
    background: linear-gradient(to right, #fcd34d, #fb923c);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .capa .sub { margin: 14px 0 0; color: #94a3b8; font-size: 13px; letter-spacing: 5px; text-transform: uppercase; font-weight: 600; }
  .capa .frase { margin: 16px auto 0; max-width: 380px; color: #64748b; font-size: 13px; font-style: italic; line-height: 1.6; }
  .capa-base { display: flex; flex-direction: column; align-items: center; gap: 14px; }
  .capa-indice { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 10px; max-width: 480px; }
  .capa-indice-item { font-size: 10.5px; letter-spacing: 2.5px; text-transform: uppercase; color: #94a3b8; font-weight: 600; }
  .capa-indice-ponto { color: rgba(251,191,36,.5); font-size: 10px; }

  /* ══ Seções ══
     Cada seção é uma <table> com <thead> (divisor + cabeçalho) e <tbody> (itens/cards) —
     assim o navegador repete o thead automaticamente no topo de toda página em que a
     tabela continuar, sem precisar prever onde a quebra vai cair. */
  .secao-table { width: 100%; border-collapse: collapse; margin: 0 0 34px; }
  /* Toda entrada em uma nova categoria começa em página nova; dentro do mesmo grupo
     (ex.: Promoções + Combos) a próxima seção pode continuar na mesma página.
     O respiro do topo vem de padding (não margin) no <td> do thead — margens do
     primeiro elemento logo após uma quebra de página são "cortadas" pelo navegador,
     então só padding garante o espaço acima do divisor/cabeçalho de forma confiável. */
  .secao-table--nova-pagina { break-before: page; }
  .secao-table--nova-pagina thead > tr > td { padding-top: 78px; }
  .secao-table--nova-pagina .divisor { margin-top: 0; }
  .secao-table thead { display: table-header-group; }
  .secao-table td { padding: 0; }
  .secao-table tbody tr { break-inside: avoid; }
  .secao-head { text-align: center; margin-bottom: 16px; break-inside: avoid; break-after: avoid; }
  .secao-head .num {
    display: inline-block; font-family: "Bebas Neue", sans-serif; font-size: 13px; letter-spacing: 4px;
    color: var(--amber); border: 1px solid rgba(251,191,36,.35); border-radius: 999px; padding: 4px 14px 3px;
    margin-bottom: 10px;
  }
  .secao-head h2 {
    margin: 0; font-family: "Bebas Neue", sans-serif; font-weight: 400;
    font-size: 32px; letter-spacing: 4px; color: #fff; line-height: 1.1;
  }
  .secao-head .tag { display: block; margin-top: 5px; font-size: 10.5px; letter-spacing: 2.5px; text-transform: uppercase; color: #64748b; font-weight: 600; }

  /* item de produto */
  .item { display: flex; align-items: baseline; gap: 10px; padding: 11px 2px; break-inside: avoid; }
  .secao-table tbody tr + tr td { border-top: 1px dashed rgba(51,65,85,.55); }
  .item .info { max-width: 62%; }
  .item .nome { font-size: 14.5px; font-weight: 700; color: #f8fafc; letter-spacing: 0.2px; }
  .item .desc { margin: 3px 0 0; font-size: 11.5px; line-height: 1.55; color: #8b98ab; }
  .item .pontos { flex: 1; border-bottom: 1px dotted rgba(148,163,184,.4); transform: translateY(-4px); min-width: 24px; }
  .item .preco { font-size: 15px; font-weight: 800; color: var(--amber); font-variant-numeric: tabular-nums; white-space: nowrap; }

  /* divisor de abertura de seção — vive dentro do <thead> da seção, junto com o
     secao-head, então repete no topo de toda página nova em que a seção continuar. */
  .divisor {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    margin: 40px 0 34px; color: rgba(251,191,36,.5);
    break-after: avoid; break-inside: avoid;
  }
  .divisor::before, .divisor::after { content: ""; height: 1px; width: 90px; background: linear-gradient(to right, transparent, rgba(251,191,36,.35)); }
  .divisor::after { transform: scaleX(-1); }

  /* ══ Combos / Promoções ══*/

  .secao-table--grid { width: calc(100% + 24px); border-collapse: separate; border-spacing: 12px 26px; margin: 0 -12px -4px; }
  .secao-table--grid td { width: 50%; vertical-align: top; }
  .combo {
    position: relative; border: 1px solid rgba(251,191,36,.25); border-radius: 14px;
    background: linear-gradient(160deg, rgba(251,191,36,.08), rgba(251,191,36,.02) 55%);
    padding: 16px 16px 14px; break-inside: avoid;
  }
  .combo.promo { border-color: rgba(167,139,250,.32); background: linear-gradient(160deg, rgba(167,139,250,.09), rgba(167,139,250,.02) 55%); }
  .combo .selo {
    position: absolute; top: -9px; left: 14px; font-size: 8.5px; font-weight: 800; letter-spacing: 1.8px; text-transform: uppercase;
    color: #0d1117; background: linear-gradient(to right, #fbbf24, #fb923c); border-radius: 999px; padding: 3px 10px;
  }
  .combo.promo .selo { background: linear-gradient(to right, #c4b5fd, #a78bfa); }
  .combo .nome { font-family: "Bebas Neue", sans-serif; font-size: 21px; letter-spacing: 1.5px; color: #fff; margin: 4px 0 6px; }
  .combo .itens { margin: 0 0 12px; font-size: 11px; line-height: 1.6; color: #94a3b8; }
  .combo .precos { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
  .combo .de { font-size: 11px; color: #64748b; text-decoration: line-through; font-variant-numeric: tabular-nums; }
  .combo .por { font-size: 20px; font-weight: 800; color: var(--amber); font-variant-numeric: tabular-nums; }
  .combo.promo .por { color: var(--violet); }
  .combo .eco {
    margin-left: auto; font-size: 9.5px; font-weight: 700; letter-spacing: 0.5px; color: var(--green);
    background: rgba(52,211,153,.1); border: 1px solid rgba(52,211,153,.25); border-radius: 999px; padding: 3px 9px;
  }

</style>
</head>
<body>
<%
  // modo controla o que é renderizado: "capa" (só a capa, sem rodapé) e "conteudo"
  // (seções + rodapé fixo, sem capa) são gerados como PDFs separados e depois
  // unidos em cardapio.controller.ts — assim o rodapé fixo nunca aparece na capa,
  // sem precisar de nenhum ajuste manual de altura pra "cobri-lo".
  var m = typeof modo !== "undefined" ? modo : "completo";
%>

<div class="pagina-moldura"></div>

<% if (m !== "capa") { %>
  <%- include("components/rodape", { restaurante: restaurante, dataGeracao: dataGeracao }) %>
<% } %>

<div class="cardapio-doc">
  <% if (m !== "conteudo") { %>
    <%- include("components/capa", { restaurante: restaurante, categorias: categoriasIndice, dataGeracao: dataGeracao }) %>
  <% } %>

  <% if (m !== "capa") { %>
    <% secoes.forEach(function (secao, i) { %>
      <%
        // Na primeira seção, quando ela é o único conteúdo deste documento (modo
        // "conteudo"), a quebra de página forçada some — senão o PDF nasceria com
        // uma página em branco antes dela.
        var s = secao;
        if (m === "conteudo" && i === 0) { s = Object.assign({}, secao, { novaPagina: false }); }
      %>
      <% if (s.tipo === "produtos") { %>
        <%- include("components/secaoProdutos", { secao: s, fmtBRL: fmtBRL }) %>
      <% } else if (s.tipo === "combos") { %>
        <%- include("components/secaoCombos", { secao: s, fmtBRL: fmtBRL }) %>
      <% } else { %>
        <%- include("components/secaoPromocoes", { secao: s, fmtBRL: fmtBRL }) %>
      <% } %>
    <% }); %>
  <% } %>
</div>

</body>
</html>
