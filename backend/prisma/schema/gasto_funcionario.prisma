// GASTO_FUNCIONARIO — pagamento de funcionários registrado manualmente

model GastoFuncionario {
  id            Int         @id @default(autoincrement())
  nome          String      @default("")
  valor         Float
  descricao     String?
  mes           Int
  ano           Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  restauranteId Int
  restaurante   Restaurante @relation(fields: [restauranteId], references: [id])
  funcionarios  GastoFuncionarioFuncionario[]

  @@map("gasto_funcionarios")
}

model GastoFuncionarioFuncionario {
  gastoFuncionarioId Int
  funcionarioId      Int

  gastoFuncionario   GastoFuncionario @relation(fields: [gastoFuncionarioId], references: [id], onDelete: Cascade)
  funcionario        Funcionario      @relation(fields: [funcionarioId], references: [id])

  @@id([gastoFuncionarioId, funcionarioId])
  @@map("gasto_funcionario_funcionarios")
}
