// GASTO_INGREDIENTE — cada compra de ingredientes registrada manualmente

model GastoIngrediente {
  id            Int         @id @default(autoincrement())
  valor         Float
  descricao     String?
  mes           Int
  ano           Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  restauranteId Int
  restaurante   Restaurante @relation(fields: [restauranteId], references: [id])

  @@map("gasto_ingredientes")
}
