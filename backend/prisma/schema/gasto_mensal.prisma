// GASTO_MENSAL — snapshot dos salários capturado no 1º lançamento do mês

model GastoMensal {
  id            Int         @id @default(autoincrement())
  mes           Int
  ano           Int
  totalSalarios Float       @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  restauranteId Int
  restaurante   Restaurante @relation(fields: [restauranteId], references: [id])

  @@unique([mes, ano, restauranteId])
  @@map("gastos_mensais")
}
